{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "address": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          }
        },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Grocery product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "discountPrice": { "type": "number" },
        "stock": { "type": "integer" },
        "category": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "brand": { "type": "string" },
        "rating": { "type": "number" },
        "isFeatured": { "type": "boolean" },
        "isTopSelling": { "type": "boolean" },
        "slug": { "type": "string" }
      },
      "required": ["name", "price", "category", "slug"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "integer" },
              "price": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "address": { "type": "object" },
        "paymentMethod": { "type": "string", "enum": ["COD", "Online"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "paymentMethod"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    }
  }
}
